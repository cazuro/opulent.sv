<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Opulent</title>
  <link rel="icon" type="image/png" href="/img/logoipoOP.png" sizes="32x32" />
  <link rel="icon" type="image/png" href="/img/logoipoOP.png" sizes="192x192" />
  <link rel="apple-touch-icon" href="/img/logoipoOP.png" sizes="180x180" />
  
</head>
<body>
  <main class="hero">
      <header class="site-header" aria-label="Encabezado principal">
        <div class="header-side header-left">
          <nav class="header-nav" aria-label="Marcas">
            <a class="header-link" href="/CataLV">Louis Vuitton</a>
            <a class="header-link" href="/CataDior">Dior</a>
            <a class="header-link" href="/CataLacoste">Lacoste</a>
          </nav>
        </div>

        <a class="brand" href="/" aria-label="Opulent">OPULENT</a>

        <div class="header-side header-right">
          <a class="header-link" href="/admin" data-admin-link hidden>Administración</a>
          <a class="header-link" href="tel:+0000000000">Llámanos</a>
          <button class="flag-button" type="button" aria-label="País: El Salvador">
            <svg class="icon-flag" viewBox="0 0 22 16" aria-hidden="true">
              <rect width="22" height="16" fill="#0038A8" />
              <rect y="5.33" width="22" height="5.34" fill="#ffffff" />
              <circle cx="11" cy="8" r="1.6" fill="#f4d44d" />
            </svg>
          </button>
        </div>
      </header>

      <% if (currentPath === "/") { %>
      <section class="hero-content" aria-label="Portada">
        <h1 class="hero-title">OPULENT</h1>
      </section>
      <% } %>
    </main>

    <style>
      :root {
        --bg: #0b0f14;
        --text: #ffffff;
        --text-muted: rgba(255, 255, 255, 0.8);
        --hairline: rgba(255, 255, 255, 0.18);
        --serif: "Didot", "Bodoni MT", "Bodoni 72", "Libre Baskerville", Baskerville, "Times New Roman",
          Times, serif;
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        height: 100%;
      }

      body {
        margin: 0;
        font-family: system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, "Apple Color Emoji",
          "Segoe UI Emoji";
        color: var(--text);
        background: var(--bg);
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      button {
        font: inherit;
        color: inherit;
        background: transparent;
        border: 0;
        padding: 0;
      }

      .site-header {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 10;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding: 18px 28px;
        background-color: rgba(0, 0, 0, 0);
        color: rgba(255, 255, 255, 0.96);
        border-bottom: 1px solid rgba(255, 255, 255, 0);
        box-shadow: none;
        backdrop-filter: none;
        -webkit-backdrop-filter: none;
        transition: background-color 180ms ease, box-shadow 180ms ease, border-color 180ms ease,
          color 180ms ease;
      }

      .site-header.is-scrolled {
        background-color: rgba(255, 255, 255, 0.96);
        color: rgba(11, 15, 20, 0.96);
        border-color: rgba(11, 15, 20, 0.08);
        box-shadow: 0 10px 26px rgba(0, 0, 0, 0.12);
        backdrop-filter: none;
        -webkit-backdrop-filter: none;
      }

      .header-side {
        display: flex;
        align-items: center;
        gap: 14px;
        min-width: 220px;
      }

      .header-left {
        min-width: unset;
      }

      .header-right {
        justify-content: flex-end;
      }

      .header-nav {
        display: flex;
        align-items: center;
        gap: 18px;
      }

      .header-link {
        font-size: 14px;
        letter-spacing: 0.04em;
        color: rgba(255, 255, 255, 0.88);
        text-transform: none;
        transition: color 120ms ease;
        white-space: nowrap;
      }

      .header-link:hover {
        color: rgba(255, 255, 255, 1);
      }

      .site-header.is-scrolled .header-link {
        color: rgba(11, 15, 20, 0.72);
      }

      .site-header.is-scrolled .header-link:hover {
        color: rgba(11, 15, 20, 0.96);
      }

      .brand {
        letter-spacing: 0.35em;
        font-weight: 600;
        font-size: 20px;
        line-height: 1;
        padding: 10px 12px;
        border-radius: 999px;
        backdrop-filter: blur(8px);
        background: rgba(0, 0, 0, 0.18);
        border: 1px solid rgba(255, 255, 255, 0.14);
        text-align: center;
      }

      .site-header.is-scrolled .brand {
        background: rgba(0, 0, 0, 0.04);
        border-color: rgba(11, 15, 20, 0.12);
      }

      .icon-button {
        width: 36px;
        height: 36px;
        display: inline-grid;
        place-items: center;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.18);
        background: rgba(0, 0, 0, 0.12);
        backdrop-filter: blur(8px);
        cursor: pointer;
        transition: transform 120ms ease, background 120ms ease, border-color 120ms ease;
      }

      .icon-button:hover {
        transform: translateY(-1px);
        background: rgba(0, 0, 0, 0.2);
        border-color: rgba(255, 255, 255, 0.24);
      }

      .site-header.is-scrolled .icon-button {
        background: rgba(0, 0, 0, 0.04);
        border-color: rgba(11, 15, 20, 0.12);
      }

      .site-header.is-scrolled .icon-button:hover {
        background: rgba(0, 0, 0, 0.07);
        border-color: rgba(11, 15, 20, 0.18);
      }

      .icon {
        width: 18px;
        height: 18px;
        fill: none;
        stroke: rgba(255, 255, 255, 0.92);
        stroke-width: 2;
        stroke-linecap: round;
        stroke-linejoin: round;
      }

      .site-header.is-scrolled .icon {
        stroke: rgba(11, 15, 20, 0.92);
      }

      .icon-flag {
        width: 22px;
        height: 16px;
        border-radius: 2px;
        box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.08);
        display: block;
      }

      .flag-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0;
        margin: 0;
        width: auto;
        height: auto;
        border: none;
        background: transparent;
        border-radius: 0;
        cursor: pointer;
      }

      .account-modal {
        position: fixed;
        inset: 0;
        display: grid;
        place-items: center;
        padding: 18px;
        z-index: 45;
        background: rgba(0, 0, 0, 0.55);
      }

      .account-card {
        width: min(92vw, 420px);
        background: rgba(255, 255, 255, 0.98);
        color: rgba(11, 15, 20, 0.96);
        border-radius: 16px;
        border: 1px solid rgba(11, 15, 20, 0.08);
        box-shadow: 0 22px 60px rgba(0, 0, 0, 0.32);
        overflow: hidden;
      }

      .account-card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 16px 16px 10px;
        border-bottom: 1px solid rgba(11, 15, 20, 0.08);
      }

      .account-title {
        margin: 0;
        font-family: var(--serif);
        font-weight: 500;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        font-size: 16px;
      }

      .account-close {
        width: 36px;
        height: 36px;
        border-radius: 999px;
        border: 1px solid rgba(11, 15, 20, 0.12);
        background: rgba(0, 0, 0, 0.03);
        color: rgba(11, 15, 20, 0.86);
        cursor: pointer;
        font-size: 22px;
        line-height: 0;
        display: inline-grid;
        place-items: center;
      }

      .account-form {
        display: grid;
        gap: 12px;
        padding: 14px 16px 16px;
      }

      .account-field {
        display: grid;
        gap: 6px;
      }

      .account-label {
        font-size: 12px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: rgba(11, 15, 20, 0.62);
      }

      .account-input {
        width: 100%;
        padding: 12px 12px;
        border-radius: 12px;
        border: 1px solid rgba(11, 15, 20, 0.12);
        background: rgba(255, 255, 255, 0.92);
        color: rgba(11, 15, 20, 0.96);
        outline: none;
      }

      .account-input:focus {
        border-color: rgba(11, 15, 20, 0.22);
        box-shadow: 0 0 0 4px rgba(11, 15, 20, 0.08);
      }

      .account-submit {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 12px 14px;
        border-radius: 999px;
        border: 1px solid rgba(11, 15, 20, 0.14);
        background: rgba(11, 15, 20, 0.96);
        color: #ffffff;
        font-family: var(--serif);
        letter-spacing: 0.08em;
        text-transform: uppercase;
        cursor: pointer;
      }

      .account-message {
        margin: 0;
        min-height: 18px;
        font-size: 12px;
        color: rgba(11, 15, 20, 0.7);
      }

      .hero-content {
        max-width: 900px;
        padding: 120px 22px 46px;
        display: grid;
        gap: 14px;
        place-items: center;
        transform: translateY(-52px);
      }

      .hero-kicker {
        margin: 0;
        font-size: 12px;
        letter-spacing: 0.25em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.75);
      }

      .hero-title {
        margin: 0;
        font-family: var(--serif);
        font-size: clamp(54px, 10vw, 122px);
        font-weight: 500;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.96);
        -webkit-text-stroke: 1px rgba(255, 255, 255, 0.14);
        text-shadow: none;
      }

      .new-arrivals {
        background: #ffffff;
        color: rgba(11, 15, 20, 0.96);
        padding: 72px 28px 96px;
      }

      .new-arrivals-inner {
        max-width: 1180px;
        margin: 0 auto;
      }

      .new-arrivals-header {
        text-align: center;
        margin: 0 0 34px;
      }

      .new-arrivals-kicker {
        margin: 0 0 6px;
        font-size: 11px;
        letter-spacing: 0.26em;
        text-transform: uppercase;
        color: rgba(11, 15, 20, 0.62);
      }

      .new-arrivals-title {
        margin: 0;
        font-family: var(--serif);
        font-weight: 500;
        font-size: clamp(30px, 4.2vw, 44px);
        letter-spacing: 0.01em;
      }

      .product-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 26px;
      }

      .product-card {
        display: grid;
        gap: 12px;
      }

      .section-actions {
        display: flex;
        justify-content: center;
        margin-top: 28px;
      }

      .more-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 12px 22px;
        border-radius: 999px;
        border: 1px solid rgba(11, 15, 20, 0.14);
        background: rgba(255, 255, 255, 0.92);
        color: rgba(11, 15, 20, 0.92);
        font-family: var(--serif);
        letter-spacing: 0.08em;
        text-transform: uppercase;
        transition: transform 120ms ease, background 120ms ease, border-color 120ms ease;
      }

      .more-button:hover {
        transform: translateY(-1px);
        background: rgba(255, 255, 255, 1);
        border-color: rgba(11, 15, 20, 0.22);
      }

      .product-media {
        position: relative;
        display: grid;
        place-items: center;
        aspect-ratio: 1 / 1;
        background: linear-gradient(180deg, rgba(0, 0, 0, 0.04), rgba(0, 0, 0, 0.02));
        border: 1px solid rgba(11, 15, 20, 0.08);
        overflow: hidden;
      }

      .wishlist {
        position: absolute;
        top: 14px;
        right: 14px;
        width: 36px;
        height: 36px;
        display: inline-grid;
        place-items: center;
        border-radius: 999px;
        border: 1px solid rgba(11, 15, 20, 0.12);
        background: rgba(255, 255, 255, 0.85);
        cursor: pointer;
        transition: transform 120ms ease, background 120ms ease, border-color 120ms ease;
        z-index: 2;
      }

      .wishlist:hover {
        transform: translateY(-1px);
        background: rgba(255, 255, 255, 0.98);
        border-color: rgba(11, 15, 20, 0.18);
      }

      .wishlist svg {
        width: 18px;
        height: 18px;
        fill: none;
        stroke: rgba(11, 15, 20, 0.82);
        stroke-width: 1.8;
      }

      .product-svg {
        width: 70%;
        height: 70%;
        opacity: 0.55;
      }

      .pm-img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        z-index: 1;
      }

      .product-media.has-img .product-svg {
        display: none;
      }

      .product-svg * {
        fill: none;
        stroke: rgba(11, 15, 20, 0.55);
        stroke-width: 1.6;
        stroke-linecap: round;
        stroke-linejoin: round;
      }

      .product-meta {
        display: grid;
        gap: 4px;
      }

      .product-name {
        margin: 0;
        font-size: 13px;
        font-weight: 500;
        color: rgba(11, 15, 20, 0.92);
      }

      .product-price {
        margin: 0;
        font-size: 12px;
        color: rgba(11, 15, 20, 0.52);
      }

      .hero-cta {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 12px 18px;
        border-radius: 999px;
        border: 1px solid var(--hairline);
        color: rgba(255, 255, 255, 0.92);
        background: rgba(0, 0, 0, 0);
        backdrop-filter: blur(10px);
        transition: transform 120ms ease, background 120ms ease, border-color 120ms ease;
      }

      .hero-cta:hover {
        transform: translateY(-1px);
        background: rgba(0, 0, 0, 0.26);
        border-color: rgba(255, 255, 255, 0.26);
      }

      .hero-cta .icon {
        width: 16px;
        height: 16px;
      }

      @media (max-width: 720px) {
        .site-header {
          padding: 14px 14px;
          justify-content: center;
          flex-wrap: wrap;
          row-gap: 10px;
        }

        .header-side {
          min-width: 0;
          gap: 10px;
          flex: 0 0 100%;
          justify-content: center;
        }

        .header-left {
          order: 2;
        }

        .header-right {
          order: 3;
        }

        .header-nav {
          justify-content: center;
          flex-wrap: wrap;
          gap: 12px;
        }

        .header-link {
          display: inline-flex;
          font-size: 12px;
          letter-spacing: 0.02em;
        }

        .brand {
          order: 1;
          width: 100%;
          text-align: center;
          font-size: 16px;
          letter-spacing: 0.28em;
        }

        .hero-content {
          transform: translateY(-30px);
        }

        .hero-title {
          letter-spacing: 0.04em;
        }

        .new-arrivals {
          padding: 56px 14px 72px;
        }

        .product-grid {
          grid-template-columns: 1fr;
          gap: 22px;
        }
      }

      @media (max-width: 1080px) {
        .product-grid {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }
      }

      .section-banner {
        width: 100%;
        aspect-ratio: 16 / 6;
        object-fit: cover;
        display: block;
        border: 1px solid rgba(11, 15, 20, 0.08);
        border-radius: 6px;
        margin: 0 0 22px;
      }

      .site-footer {
        background: #ffffff;
        color: rgba(11, 15, 20, 0.92);
        border-top: 1px solid rgba(11, 15, 20, 0.08);
        padding: 56px 28px 28px;
      }

      .footer-inner {
        max-width: 1180px;
        margin: 0 auto;
        display: grid;
        gap: 28px;
      }

      .footer-top {
        display: grid;
        grid-template-columns: 1.2fr repeat(3, 1fr);
        gap: 26px;
        align-items: start;
      }

      .footer-logo {
        margin: 0 0 10px;
        font-family: var(--serif);
        font-size: clamp(24px, 4vw, 36px);
        letter-spacing: 0.28em;
        text-transform: uppercase;
      }

      .footer-title {
        margin: 0 0 10px;
        font-size: 13px;
        letter-spacing: 0.26em;
        text-transform: uppercase;
        color: rgba(11, 15, 20, 0.62);
      }

      .footer-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: grid;
        gap: 8px;
      }

      .footer-link {
        color: rgba(11, 15, 20, 0.92);
        transition: color 120ms ease, transform 120ms ease;
      }

      .footer-link:hover {
        color: rgba(11, 15, 20, 1);
        transform: translateX(2px);
      }

      .footer-brands {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 8px 18px;
        color: rgba(11, 15, 20, 0.8);
        font-size: 13px;
      }

      .footer-contact {
        display: grid;
        gap: 10px;
      }

      .footer-contact-row {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        color: rgba(11, 15, 20, 0.92);
      }

      .icon-dark {
        width: 18px;
        height: 18px;
        stroke: rgba(11, 15, 20, 0.96);
        fill: none;
        stroke-width: 2;
        stroke-linecap: round;
        stroke-linejoin: round;
      }

      .social {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        margin-top: 6px;
      }

      .footer-bottom {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding-top: 18px;
        border-top: 1px solid rgba(11, 15, 20, 0.08);
        font-size: 12px;
        color: rgba(11, 15, 20, 0.62);
      }

      .payments {
        display: inline-flex;
        align-items: center;
        gap: 10px;
      }

      .payment-icon {
        width: 28px;
        height: 18px;
        stroke: rgba(11, 15, 20, 0.96);
        fill: none;
        stroke-width: 1.6;
        border-radius: 2px;
      }

      @media (max-width: 900px) {
        .footer-top {
          grid-template-columns: 1fr;
        }

        .footer-bottom {
          flex-direction: column;
          align-items: flex-start;
          gap: 8px;
        }
      }
    </style>

    <script>
      (() => {
        const header = document.querySelector(".site-header");
        if (!header) return;

        const onScroll = () => {
          header.classList.toggle("is-scrolled", window.scrollY > 10);
        };

        onScroll();
        window.addEventListener("scroll", onScroll, { passive: true });
      })();
    </script>

    <script>
      (() => {
        const modal = document.querySelector("[data-account-modal]");
        const form = document.querySelector("[data-account-form]");
        const message = document.querySelector("[data-account-message]");

        if (!modal || !form || !message) return;

        const setOpen = (isOpen) => {
          modal.hidden = !isOpen;
          document.body.style.overflow = isOpen ? "hidden" : "";
          if (!isOpen) {
            const passwordInput = form.querySelector("input[name='password']");
            if (passwordInput) passwordInput.value = "";
            message.textContent = "";
          }
        };

        document.addEventListener("click", (e) => {
          if (e.target.closest("[data-account-open]")) {
            setOpen(true);
            return;
          }
          if (e.target.closest("[data-account-close]")) {
            setOpen(false);
            return;
          }
          if (e.target === modal) {
            setOpen(false);
          }
        }, { passive: true });

        window.addEventListener("keydown", (e) => {
          if (e.key === "Escape") setOpen(false);
        });

        form.addEventListener("submit", async (e) => {
          e.preventDefault();
          message.textContent = "Verificando...";

          const formData = new FormData(form);
          const payload = {
            name: String(formData.get("name") || "").trim(),
            email: String(formData.get("email") || "").trim(),
            password: String(formData.get("password") || ""),
          };

          try {
            const res = await fetch("/api/auth/login", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify(payload),
            });

            const data = await res.json().catch(() => ({}));
            if (!res.ok) {
              message.textContent = data?.message || "Datos incorrectos.";
              return;
            }

            message.textContent = "Listo.";
            const passwordInput = form.querySelector("input[name='password']");
            if (passwordInput) passwordInput.value = "";
            setOpen(false);
          } catch {
            message.textContent = "Error de conexión.";
          }
        });
      })();
    </script>

    <script>
      (() => {
        const adminButton = document.querySelector(".flag-button");
        const adminLink = document.querySelector("[data-admin-link]");
        if (!adminButton || !adminLink) return;

        const ADMIN_CODE = "13032007";
        const ADMIN_KEY = "opulent_admin_authed";

        const hasCookie = document.cookie.split(";").some((c) => c.trim() === "opulent_admin=1");
        if (hasCookie) {
          window.localStorage.setItem(ADMIN_KEY, "1");
        }

        const isAdmin = () => window.localStorage.getItem(ADMIN_KEY) === "1";
        const setAdmin = (value) => {
          if (value) {
            window.localStorage.setItem(ADMIN_KEY, "1");
            document.cookie = "opulent_admin=1; Path=/; SameSite=Lax";
          } else {
            window.localStorage.removeItem(ADMIN_KEY);
            document.cookie = "opulent_admin=; Path=/; Max-Age=0; SameSite=Lax";
          }
          adminLink.hidden = !value;
        };

        adminLink.hidden = !isAdmin();

        adminButton.addEventListener("click", () => {
          if (isAdmin()) {
            setAdmin(false);
            if (window.location.pathname === "/admin") {
              window.location.href = "/";
            }
            return;
          }

          const input = window.prompt("Ingrese el número");
          if (input == null) return;
          if (String(input).trim() === ADMIN_CODE) {
            setAdmin(true);
            window.location.href = "/admin";
          }
        });
      })();
    </script>
