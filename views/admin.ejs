<%- include('partials/header') %>

<main class="admin" aria-label="Administración">
  <section class="admin-inner" aria-label="Publicar producto">
    <div class="admin-header">
      <h1 class="admin-title">Administración</h1>
      <p class="admin-subtitle">Publica, edita o elimina productos</p>
    </div>

    <form class="admin-form" id="adminForm">
      <input type="hidden" name="id" id="productId" value="" />

      <label class="admin-field">
        <span class="admin-label">Categoría</span>
        <select class="admin-input" name="category" id="category" required>
          <option value="Louis Vuitton">Catálogo Louis Vuitton</option>
          <option value="Dior">Catálogo Dior</option>
          <option value="Lacoste">Catálogo Lacoste</option>
          <option value="Perfumes">Categoría Perfumes</option>
          <option value="Camisas">Categoría Camisas</option>
          <option value="Carteras">Categoría Carteras</option>
        </select>
      </label>

      <label class="admin-field">
        <span class="admin-label">Portada</span>
        <input class="admin-input" name="cover" id="cover" type="file" accept="image/*" />
      </label>

      <label class="admin-field">
        <span class="admin-label">Imágenes</span>
        <input class="admin-input" name="images" id="images" type="file" accept="image/*" multiple />
      </label>

      <label class="admin-field admin-inline">
        <span class="admin-label">Reemplazar imágenes</span>
        <input class="admin-checkbox" name="replaceImages" id="replaceImages" type="checkbox" />
      </label>

      <label class="admin-field">
        <span class="admin-label">Nombre del producto</span>
        <input class="admin-input" name="name" id="name" type="text" required />
      </label>

      <label class="admin-field">
        <span class="admin-label">Precio</span>
        <input class="admin-input" name="price" id="price" type="number" step="0.01" min="0" required />
      </label>

      <label class="admin-field">
        <span class="admin-label">Descuento (%)</span>
        <input class="admin-input" name="discount" id="discount" type="number" step="1" min="0" max="100" />
      </label>

      <div class="admin-field" id="sizeStockWrap" hidden>
        <span class="admin-label">Inventario por talla</span>
        <div class="admin-stock" id="sizeStockList" aria-label="Inventario por talla"></div>
      </div>

      <div class="admin-actions">
        <button class="admin-submit" type="submit" id="submitBtn">Publicar</button>
        <button class="admin-cancel" type="button" id="cancelEdit" hidden>Cancelar</button>
        <p class="admin-message" id="adminMessage" aria-live="polite"></p>
      </div>
    </form>

    <section class="admin-list" aria-label="Productos publicados">
      <h2 class="admin-section-title">Productos</h2>
      <div class="product-grid" id="productGrid"></div>
    </section>
  </section>
</main>

<style>
  .admin {
    background: #ffffff;
    color: rgba(11, 15, 20, 0.96);
    padding: 116px 28px 96px;
  }

  .admin-inner {
    max-width: 1180px;
    margin: 0 auto;
    display: grid;
    gap: 28px;
  }

  .admin-header {
    display: grid;
    gap: 8px;
  }

  .admin-title {
    margin: 0;
    font-family: var(--serif);
    font-size: clamp(26px, 4vw, 40px);
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .admin-subtitle {
    margin: 0;
    color: rgba(11, 15, 20, 0.62);
  }

  .admin-form {
    display: grid;
    gap: 14px;
    padding: 18px;
    border-radius: 18px;
    border: 1px solid rgba(11, 15, 20, 0.08);
    background: rgba(255, 255, 255, 0.98);
  }

  .admin-field {
    display: grid;
    gap: 6px;
  }

  .admin-stock {
    display: grid;
    gap: 10px;
    padding: 12px 12px;
    border-radius: 12px;
    border: 1px solid rgba(11, 15, 20, 0.12);
    background: rgba(255, 255, 255, 0.92);
  }

  .admin-stock-row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 10px;
  }

  .admin-stock-check {
    width: 18px;
    height: 18px;
  }

  .admin-stock-size {
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(11, 15, 20, 0.8);
  }

  .admin-stock-qty {
    width: 96px;
    padding: 10px 10px;
    border-radius: 10px;
    border: 1px solid rgba(11, 15, 20, 0.12);
    background: rgba(255, 255, 255, 0.96);
    color: rgba(11, 15, 20, 0.96);
    outline: none;
  }

  .admin-inline {
    grid-auto-flow: column;
    justify-content: start;
    align-items: center;
    gap: 10px;
  }

  .admin-label {
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(11, 15, 20, 0.62);
  }

  .admin-input {
    width: 100%;
    padding: 12px 12px;
    border-radius: 12px;
    border: 1px solid rgba(11, 15, 20, 0.12);
    background: rgba(255, 255, 255, 0.92);
    color: rgba(11, 15, 20, 0.96);
    outline: none;
  }

  .admin-input:focus {
    border-color: rgba(11, 15, 20, 0.22);
    box-shadow: 0 0 0 4px rgba(11, 15, 20, 0.08);
  }

  .admin-checkbox {
    width: 18px;
    height: 18px;
  }

  .admin-actions {
    display: grid;
    grid-template-columns: auto auto 1fr;
    gap: 12px;
    align-items: center;
  }

  .admin-submit,
  .admin-cancel {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12px 14px;
    border-radius: 999px;
    border: 1px solid rgba(11, 15, 20, 0.14);
    font-family: var(--serif);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
  }

  .admin-submit {
    background: rgba(11, 15, 20, 0.96);
    color: #ffffff;
  }

  .admin-cancel {
    background: rgba(0, 0, 0, 0.03);
    color: rgba(11, 15, 20, 0.9);
  }

  .admin-message {
    margin: 0;
    font-size: 12px;
    color: rgba(11, 15, 20, 0.7);
    min-height: 18px;
  }

  .admin-list {
    display: grid;
    gap: 14px;
  }

  .admin-section-title {
    margin: 0;
    font-family: var(--serif);
    font-size: 18px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 18px;
  }

  @media (max-width: 1000px) {
    .product-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .product-grid {
      grid-template-columns: 1fr;
    }

    .admin-actions {
      grid-template-columns: 1fr;
    }
  }

  .product-card {
    border-radius: 16px;
    border: 1px solid rgba(11, 15, 20, 0.08);
    overflow: hidden;
    background: #ffffff;
  }

  .product-media {
    position: relative;
    aspect-ratio: 1 / 1;
    background: rgba(11, 15, 20, 0.03);
  }

  .pm-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .product-meta {
    padding: 12px 12px 12px;
    display: grid;
    gap: 6px;
  }

  .product-name {
    margin: 0;
    font-size: 13px;
    font-weight: 600;
  }

  .product-price {
    margin: 0;
    font-size: 12px;
    color: rgba(11, 15, 20, 0.62);
  }

  .product-actions {
    display: flex;
    gap: 10px;
    padding: 0 12px 12px;
  }

  .product-action {
    padding: 10px 12px;
    border-radius: 999px;
    border: 1px solid rgba(11, 15, 20, 0.12);
    background: rgba(0, 0, 0, 0.02);
    cursor: pointer;
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
</style>

<script>
  (() => {
    const ADMIN_KEY = "opulent_admin_authed";
    const hasCookie = document.cookie.split(";").some((c) => c.trim() === "opulent_admin=1");
    if (hasCookie) {
      window.localStorage.setItem(ADMIN_KEY, "1");
    }
    if (window.localStorage.getItem(ADMIN_KEY) !== "1") {
      window.location.href = "/";
      return;
    }

    const form = document.getElementById("adminForm");
    const grid = document.getElementById("productGrid");
    const message = document.getElementById("adminMessage");
    const submitBtn = document.getElementById("submitBtn");
    const cancelEdit = document.getElementById("cancelEdit");

    const idInput = document.getElementById("productId");
    const categoryInput = document.getElementById("category");
    const coverInput = document.getElementById("cover");
    const imagesInput = document.getElementById("images");
    const replaceImagesInput = document.getElementById("replaceImages");
    const nameInput = document.getElementById("name");
    const priceInput = document.getElementById("price");
    const discountInput = document.getElementById("discount");
    const sizeStockWrap = document.getElementById("sizeStockWrap");
    const sizeStockList = document.getElementById("sizeStockList");

    const SHOES_CATEGORIES = new Set(["Louis Vuitton", "Dior", "Lacoste"]);
    const SIZES_SHOES = ["7", "8", "9", "10", "11", "12"];
    const SIZES_CAMISAS = ["XS", "S", "M", "L", "XL"];

    const getSizesForCategory = (cat) => {
      if (String(cat) === "Camisas") return SIZES_CAMISAS;
      if (SHOES_CATEGORIES.has(String(cat))) return SIZES_SHOES;
      return null;
    };

    let stockListenerAttached = false;

    const getStockMapFromUI = () => {
      const map = new Map();
      if (!sizeStockList || !sizeStockWrap || sizeStockWrap.hidden) return map;
      const rows = Array.from(sizeStockList.querySelectorAll(".admin-stock-row"));
      rows.forEach((row) => {
        const size = row.getAttribute("data-size") || "";
        const check = row.querySelector("input.admin-stock-check");
        const qtyInput = row.querySelector("input.admin-stock-qty");
        if (!(check instanceof HTMLInputElement) || !(qtyInput instanceof HTMLInputElement)) return;
        if (!check.checked) return;
        const qty = Math.floor(Number(qtyInput.value));
        map.set(size, Number.isFinite(qty) && qty >= 0 ? qty : 0);
      });
      return map;
    };

    const renderStockUI = (cat, seedMap) => {
      if (!sizeStockWrap || !sizeStockList) return;
      const sizes = getSizesForCategory(cat);
      if (!sizes) {
        sizeStockWrap.hidden = true;
        sizeStockList.innerHTML = "";
        return;
      }

      sizeStockWrap.hidden = false;
      sizeStockList.innerHTML = sizes
        .map((s) => {
          const qty = seedMap instanceof Map && seedMap.has(s) ? seedMap.get(s) : 0;
          const checked = seedMap instanceof Map && seedMap.has(s);
          const disabled = checked ? "" : "disabled";
          return `<div class="admin-stock-row" data-size="${s}"><input class="admin-stock-check" type="checkbox" ${checked ? "checked" : ""} aria-label="Usar talla ${s}" /><span class="admin-stock-size">${s}</span><input class="admin-stock-qty" type="number" min="0" step="1" value="${qty}" ${disabled} aria-label="Unidades para talla ${s}" /></div>`;
        })
        .join("");

      if (!stockListenerAttached) {
        stockListenerAttached = true;
        sizeStockList.addEventListener(
          "change",
          (e) => {
            const t = e.target;
            if (!(t instanceof HTMLElement)) return;
            if (!t.classList.contains("admin-stock-check")) return;
            const row = t.closest(".admin-stock-row");
            if (!row) return;
            const qtyInput = row.querySelector("input.admin-stock-qty");
            if (!(qtyInput instanceof HTMLInputElement)) return;
            qtyInput.disabled = !t.checked;
            if (t.checked && qtyInput.value === "") qtyInput.value = "0";
          },
          { passive: true }
        );
      }
    };

    const money = (n) => {
      const v = Number(n);
      if (!Number.isFinite(v)) return "$0";
      return `$${v.toFixed(2)}`;
    };

    const buildArticle = (p) => {
      const article = document.createElement("article");
      article.className = "product-card";
      article.dataset.id = p._id;

      const media = document.createElement("div");
      media.className = "product-media";
      const img = document.createElement("img");
      img.className = "pm-img";
      img.loading = "lazy";
      img.decoding = "async";
      img.alt = p.name || "Producto";
      img.src = Array.isArray(p.images) && p.images[0] ? p.images[0] : "";
      media.appendChild(img);

      const meta = document.createElement("div");
      meta.className = "product-meta";
      const h3 = document.createElement("h3");
      h3.className = "product-name";
      h3.textContent = p.name || "";
      const price = document.createElement("p");
      price.className = "product-price";
      const discount = Number(p.discount || 0);
      const base = money(p.price);
      const final = discount > 0 ? money(Number(p.price) * (1 - discount / 100)) : base;
      price.textContent =
        discount > 0 ? `${p.category} · ${base} → ${final} (-${discount}%)` : `${p.category} · ${base}`;
      meta.appendChild(h3);
      meta.appendChild(price);

      const actions = document.createElement("div");
      actions.className = "product-actions";
      const edit = document.createElement("button");
      edit.type = "button";
      edit.className = "product-action";
      edit.textContent = "Editar";
      edit.addEventListener("click", () => startEdit(p));

      const del = document.createElement("button");
      del.type = "button";
      del.className = "product-action";
      del.textContent = "Eliminar";
      del.addEventListener("click", async () => {
        const ok = window.confirm("¿Eliminar este producto?");
        if (!ok) return;
        message.textContent = "Eliminando...";
        const res = await fetch(`/api/admin/products/${encodeURIComponent(p._id)}`, { method: "DELETE" });
        if (!res.ok) {
          const data = await res.json().catch(() => ({}));
          message.textContent = data?.message || "No se pudo eliminar.";
          return;
        }
        message.textContent = "Eliminado.";
        await load();
      });

      actions.appendChild(edit);
      actions.appendChild(del);

      article.appendChild(media);
      article.appendChild(meta);
      article.appendChild(actions);
      return article;
    };

    const resetForm = () => {
      idInput.value = "";
      submitBtn.textContent = "Publicar";
      cancelEdit.hidden = true;
      replaceImagesInput.checked = false;
      coverInput.value = "";
      imagesInput.value = "";
      message.textContent = "";
      renderStockUI(categoryInput.value, new Map());
    };

    const startEdit = (p) => {
      const stockMap = new Map();
      const stockRows = Array.isArray(p?.stockBySize) ? p.stockBySize : [];
      stockRows.forEach((row) => {
        const size = String(row?.size || "").trim();
        const qty = Math.floor(Number(row?.qty));
        if (!size) return;
        if (!Number.isFinite(qty) || qty < 0) return;
        stockMap.set(size, qty);
      });

      idInput.value = p._id;
      categoryInput.value = p.category;
      nameInput.value = p.name;
      priceInput.value = String(p.price);
      discountInput.value = p.discount == null ? "" : String(p.discount);
      submitBtn.textContent = "Actualizar";
      cancelEdit.hidden = false;
      renderStockUI(p.category, stockMap);
      window.scrollTo({ top: 0, behavior: "smooth" });
    };

    cancelEdit.addEventListener("click", resetForm);

    const load = async () => {
      const res = await fetch("/api/products");
      const data = await res.json().catch(() => ({}));
      const products = Array.isArray(data.products) ? data.products : [];
      grid.innerHTML = "";
      products.forEach((p) => grid.appendChild(buildArticle(p)));
    };

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      message.textContent = idInput.value ? "Actualizando..." : "Publicando...";

      const fd = new FormData();
      fd.set("category", categoryInput.value);
      fd.set("name", nameInput.value);
      fd.set("price", priceInput.value);
      fd.set("discount", discountInput.value);
      fd.set(
        "stockBySize",
        JSON.stringify(Array.from(getStockMapFromUI().entries()).map(([size, qty]) => ({ size, qty })))
      );
      fd.set("replaceImages", replaceImagesInput.checked ? "1" : "0");
      const coverFile = coverInput?.files && coverInput.files[0] ? coverInput.files[0] : null;
      if (coverFile) fd.append("cover", coverFile);
      const files = Array.from(imagesInput.files || []);
      files.forEach((f) => fd.append("images", f));

      const isEdit = Boolean(idInput.value);
      const url = isEdit ? `/api/admin/products/${encodeURIComponent(idInput.value)}` : "/api/admin/products";
      const method = isEdit ? "PUT" : "POST";

      const res = await fetch(url, { method, body: fd });
      const data = await res.json().catch(() => ({}));
      if (!res.ok) {
        message.textContent = data?.message || "No se pudo guardar.";
        return;
      }

      message.textContent = isEdit ? "Actualizado." : "Publicado.";
      resetForm();
      await load();
    });

    categoryInput.addEventListener("change", () => {
      renderStockUI(categoryInput.value, getStockMapFromUI());
    });

    renderStockUI(categoryInput.value, new Map());
    load();
  })();
</script>

<%- include('partials/footer') %>
